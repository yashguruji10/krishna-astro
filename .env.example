# MongoDB connection string (use MongoDB Atlas free tier, or local MongoDB)
MONGODB_URI=mongodb://localhost:27017/jay_durga_jyotish

# Secret used to sign admin/user login tokens (use a long random string)
JWT_SECRET=change_this_to_a_long_random_secret_string

# Default admin account (created automatically on first run / seed)
ADMIN_EMAIL=admin@jaydurgajyotish.com
ADMIN_PASSWORD=change_this_password

# SMTP settings - works with any provider that gives free SMTP access
# (e.g. Gmail with an "App Password", Brevo/Sendinblue free tier, Zoho Mail free tier)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Jay Durga Jyotish <your_email@gmail.com>"

# Email address where new order/enquiry notifications are sent
NOTIFY_EMAIL=owner_email@gmail.com

# Public site URL (used for links in emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp number used for "Send via WhatsApp" links (with country code, no +, no spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=919426893180
